---
import { footerKeywordGroups } from '../lib/seoKeywords';

const { lang = 'es', showEventsNews = true } = Astro.props;
const path = Astro.url?.pathname ?? '';
const resolvedLang = path.startsWith('/en/') ? 'en' : path.startsWith('/es/') ? 'es' : lang;
const isEn = resolvedLang === 'en';

const infoLinks =
  isEn
    ? [
        { href: '/en/#collections', label: 'Collections' },
        { href: '/en/#layla', label: 'Layla' },
        { href: '/en/contact', label: 'Contact' },
      ]
    : [
        { href: '/#colecciones', label: 'Colecciones' },
        { href: '/#layla', label: 'Layla' },
        { href: '/contacto', label: 'Contacto' },
      ];
const legalLinks =
  isEn
    ? [
        { href: '/en/terms-and-conditions/', label: 'Terms and Conditions of Use' },
        { href: '/en/return-policy/', label: 'Return Policy' },
        { href: '/en/warranties-and-authenticity/', label: 'Warranties and Authenticity' },
        { href: '/en/texas-taxes/', label: 'Taxes – Texas' },
        { href: '/en/privacy', label: 'Privacy Notice' },
      ]
    : [
        { href: '/es/condiciones-generales-de-uso/', label: 'Condiciones Generales de Uso' },
        { href: '/es/politica-de-devoluciones/', label: 'Política de Devoluciones' },
        { href: '/es/garantias-y-autenticidad/', label: 'Garantías y Autenticidad' },
        { href: '/es/impuestos-texas/', label: 'Impuestos – Texas' },
        { href: '/aviso-privacidad', label: 'Aviso de Privacidad' },
      ];
const contactTitle = isEn ? 'Contact' : 'Contacto';
const infoTitle = isEn ? 'Information' : 'Información';
const visitorTitle = isEn ? 'Visitor Information' : 'Información del Visitante';
const hoursTitle = isEn ? 'Contact Hours' : 'Horarios de Contacto';
const locationTitle = isEn ? 'Location' : 'Ubicación';
const legalTitle = isEn ? 'Legal' : 'Avisos legales';
const madeByText = isEn ? 'made by o7Digital' : 'hecho por o7Digital';
const logoAlt = 'My Light Art Gallery';
const copyright =
  isEn
    ? '© 2026 My Light Gallery Art. All rights reserved.'
    : '© 2026 My Light Gallery Art. Todos los derechos reservados.';
const hours =
  isEn
    ? ['Monday - Friday: 10:00 - 18:00', 'Saturday: By appointment']
    : ['Lunes - Viernes: 10:00 - 18:00', 'Sábado: Con cita previa'];
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img
        src="/logo/MY%20LIGHT%20ART%20GALLERY%20colourLOGO.png"
        alt={logoAlt}
        class="footer-logo"
      />
    </div>

    <div class="footer-info">
      <strong>{infoTitle}</strong>
      {infoLinks.map((link) => (
        <p><a href={link.href}>{link.label}</a></p>
      ))}
    </div>

    <div>
      <strong>{legalTitle}</strong>
      {legalLinks.map((link) => (
        <p><a href={link.href}>{link.label}</a></p>
      ))}
    </div>

    <div>
      <strong>{visitorTitle}</strong>
      <p><strong>{hoursTitle}</strong></p>
      {hours.map((h) => (
        <p>{h}</p>
      ))}
      <p style="margin-top: 1rem;"><strong>{locationTitle}</strong></p>
      <p>Irving, Texas</p>
    </div>

    <div>
      <strong>{contactTitle}</strong>
      <p>Email: <a href="mailto:layla@mylightartgallery.com">layla@mylightartgallery.com</a></p>
      <p>Tel: <a href="tel:+12145376953">+1 (214) 537-6953</a></p>
    </div>
  </div>

  <div class="container footer-keywords" aria-label="Local SEO keywords">
    {footerKeywordGroups.map((group) => (
      <p class="footer-keywords__line">
        <span class="footer-keywords__label">{group.label}:</span>
        <span>{group.keywords.join(' · ')}</span>
      </p>
    ))}
  </div>

  <div class="footer-bottom">
    <span>{copyright}</span>
    <a href="https://www.o7digital.com" target="_blank" class="made-by">{madeByText}</a>
  </div>
</footer>

<style>
  .site-footer {
    background: rgb(229, 225, 212);
    padding: 3rem 2rem 1rem;
    margin-top: 4rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(200px, 280px) repeat(4, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 0;
  }

  .footer-logo {
    width: 170px;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .footer-grid strong {
    display: block;
    margin-bottom: 1rem;
    font-size: 1.1rem;
    color: #3b3b3b;
  }

  .footer-grid p {
    margin: 0.5rem 0;
    color: #555;
    font-size: 0.95rem;
  }

  .footer-grid a {
    color: #555;
    text-decoration: none;
    transition: color 0.3s;
  }

  .footer-grid a:hover {
    color: #000;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 1.5rem;
    border-top: 1px solid #ddd;
    color: #777;
    font-size: 0.9rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-keywords {
    margin-bottom: 1.5rem;
    text-align: center;
    color: #6a6358;
  }

  .footer-keywords__line {
    margin: 0.45rem 0;
    font-size: 0.74rem;
    line-height: 1.8;
    letter-spacing: 0.02em;
  }

  .footer-keywords__label {
    font-weight: 600;
    color: #494238;
    margin-right: 0.45rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .made-by {
    color: #777;
    text-decoration: none;
    transition: color 0.3s;
  }

  .made-by:hover {
    color: #000;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
  }

  @media (max-width: 768px) {
    .footer-brand {
      margin-left: 0;
      justify-content: center;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
    }

    .footer-keywords__line {
      font-size: 0.7rem;
    }

    .footer-logo {
      width: 140px;
      height: auto;
      object-fit: contain;
    }
  }
</style>
